<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.pdynet.acmemanager.controller.AcmeRegistrationsViewController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="ACME Registrations"><font><Font name="System Bold" size="22.0" /></font></Label>
                <HBox HBox.hgrow="ALWAYS" />
                <Button fx:id="btnDelete" disable="true" onAction="#handleDelete" prefHeight="35.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
                <Button fx:id="btnRename" disable="true" onAction="#handleRename" prefHeight="35.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Rename" />
                <Separator orientation="VERTICAL" />
                <Button onAction="#handleNew" prefHeight="35.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="+ New Registration" />
            </children>
        </HBox>
        <TableView fx:id="tableRegistrations" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName" text="Friendly Name" prefWidth="200" />
                <TableColumn fx:id="colUrl" text="Server URL" prefWidth="400" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
    </children>
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
</VBox>
