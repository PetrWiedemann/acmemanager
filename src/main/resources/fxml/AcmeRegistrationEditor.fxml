<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.pdynet.acmemanager.controller.AcmeRegistrationEditorController">
   <children>
      <Label text="ACME Account Setup">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Separator />
      <GridPane hgap="10.0" vgap="15.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
          <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Friendly Name:" />
            <TextField fx:id="txtName" promptText="e.g. Let's Encrypt Prod" GridPane.columnIndex="1" />
            
            <Label text="Directory URL:" GridPane.rowIndex="1" />
            <TextField fx:id="txtUrl" promptText="acme://letsencrypt.org" GridPane.rowIndex="1" GridPane.columnIndex="1" />
            
            <Label text="Contact Email:" GridPane.rowIndex="2" />
            <TextField fx:id="txtEmail" promptText="admin@example.com" GridPane.rowIndex="2" GridPane.columnIndex="1" />

            <Label text="Security:" GridPane.rowIndex="3" />
            <CheckBox fx:id="chbTrustAll" text="Trust all certificates (Bypass SSL validation)" GridPane.rowIndex="3" GridPane.columnIndex="1" />
         </children>
      </GridPane>
      <Separator />
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCancel" prefWidth="80.0" prefHeight="35.0" text="Cancel" />
            <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSave" prefWidth="140.0" prefHeight="35.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Register Account" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
