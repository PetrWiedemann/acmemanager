<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="550.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.pdynet.acmemanager.controller.DnsProviderEditorController">
   <children>
      <Label text="DNS Provider Configuration">
         <font><Font name="System Bold" size="18.0" /></font>
      </Label>
      <Separator />
      
      <GridPane hgap="10.0" vgap="12.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
          <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Provider Name:" />
            <TextField fx:id="txtName" promptText="e.g. My DNS Provider Account" GridPane.columnIndex="1" />
            
            <Label text="DNS Service:" GridPane.rowIndex="1" />
            <ComboBox fx:id="cbService" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="API Key:" GridPane.rowIndex="2" />
            <StackPane GridPane.columnIndex="1" GridPane.rowIndex="2">
               <children>
                  <TextField fx:id="txtApiKey" visible="false" />
                  <PasswordField fx:id="passApiKey" />
                  <ToggleButton fx:id="btnShowApiKey" onAction="#toggleKeyVisibility" text="👁" StackPane.alignment="CENTER_RIGHT" />
               </children>
            </StackPane>
            
            <Label text="Secret Key:" GridPane.rowIndex="3" />
            <StackPane GridPane.columnIndex="1" GridPane.rowIndex="3">
               <children>
                  <TextField fx:id="txtSecretKey" visible="false" />
                  <PasswordField fx:id="passSecretKey" />
                  <ToggleButton fx:id="btnShowSecretKey" onAction="#toggleKeyVisibility" text="👁" StackPane.alignment="CENTER_RIGHT" />
               </children>
            </StackPane>
         </children>
      </GridPane>

      <VBox spacing="3.0">
         <children>
            <Label text="Note for TSIG (Dynamic DNS) users:" textFill="#7f8c8d">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label text="API Key format: ALGORITHM;IP_ADDRESS;KEY_NAME (e.g. HMAC-SHA256;192.168.1.10;cert-key)" textFill="#7f8c8d">
               <font>
                  <Font name="System Italic" size="12.0" />
               </font>
            </Label>
            <Label text="Secret Key format: Your Base64 encoded TSIG secret" textFill="#7f8c8d">
               <font>
                  <Font name="System Italic" size="12.0" />
               </font>
            </Label>
         </children>
         <VBox.margin>
            <Insets top="5.0" />
         </VBox.margin>
      </VBox>

      <Separator />
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCancel" text="Cancel" prefHeight="35.0" />
            <Button mnemonicParsing="false" onAction="#handleSave" prefHeight="35.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Save Provider" />
         </children>
      </HBox>
   </children>
   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
</VBox>