<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.pdynet.acmemanager.controller.DnsProvidersViewController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Label text="DNS Providers">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
            <HBox HBox.hgrow="ALWAYS" />
            
            <Button fx:id="btnDelete" disable="true" mnemonicParsing="false" onAction="#handleDelete" prefHeight="35.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Delete" />
            
            <Button fx:id="btnEdit" disable="true" mnemonicParsing="false" onAction="#handleEdit" prefHeight="35.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edit Selected" />
            
            <Separator orientation="VERTICAL" />
            
            <Button mnemonicParsing="false" onAction="#handleNew" prefHeight="35.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="+ New Provider" />
         </children>
      </HBox>
      
      <TableView fx:id="tableProviders" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colName" prefWidth="300.0" text="Account Name / Description" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      
      <HBox alignment="CENTER_LEFT" prefHeight="25.0" spacing="5.0">
         <children>
            <Label text="Note: These providers are used for DNS-01 challenges." textFill="#7f8c8d">
               <font>
                  <Font name="System Italic" size="12.0" />
               </font>
            </Label>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
